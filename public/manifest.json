{
  "schemaVersion": "1.5.1",
  "key": "clockify-quickbooks-bridge",
  "name": "QuickBooks Payroll Bridge",
  "description": "Automatically send and synchronize invoices directly to your QuickBooks account.",
  "baseUrl": "https://app.automaticon.online",
  "minimalSubscriptionPlan": "STANDARD",
  "iconPath": "/qb-logo.png",
  "scopes": [
    "WORKSPACE_READ",
    "INVOICE_READ",
    "INVOICE_WRITE"
  ],
  "lifecycle": [
    {
      "path": "/api/marketplace/install",
      "type": "INSTALLED"
    },
    {
      "path": "/api/marketplace/uninstall",
      "type": "DELETED"
    }
  ],
  "settings": "/settings",
  "components": [
    {
      "type": "sidebar",
      "label": "QuickBooks Bridge",
      "path": "/settings",
      "accessLevel": "ADMINS",
      "iconPath": "/qb-logo.png"
    },
    {
      "type": "invoices.action",
      "label": "Send to QuickBooks",
      "path": "/api/actions/invoice",
      "accessLevel": "ADMINS",
      "iconPath": "/qb-logo.png"
    }
  ]
}
