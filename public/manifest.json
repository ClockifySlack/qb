{
  "schemaVersion": "1.3",
  "key": "clockify-quickbooks-bridge",
  "name": "QuickBooks Payroll Bridge",
  "description": "Automatically sync and push Clockify invoices directly into your QuickBooks Payroll account.",
  "baseUrl": "https://qb-opal.vercel.app",
  "minimalSubscriptionPlan": "STANDARD",
  "scopes": [
    "WORKSPACE_READ",
    "INVOICE_READ",
    "INVOICE_WRITE"
  ],
  "lifecycle": [
    {
      "path": "/api/marketplace/install",
      "type": "INSTALLED"
    },
    {
      "path": "/api/marketplace/uninstall",
      "type": "DELETED"
    }
  ],
  "settings": "/settings",
  "components": [
    {
      "type": "send-invoice-to-action",
      "label": "QuickBooks",
      "path": "/sync-invoice-modal"
    }
  ]
}
